# PostgreSQL/TimescaleDB Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fraud_detection
DB_USER=postgres
DB_PASSWORD=12345

# For Spark JDBC connection (required by diagnostic script)
POSTGRES_URL=jdbc:postgresql://localhost:5432/fraud_detection
POSTGRES_USER=postgres
POSTGRES_PASSWORD=12345

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=creditcardTransaction
KAFKA_GROUP_ID=fraud-detection-consumer

# Spark Configuration
SPARK_MASTER=local[*]
SPARK_APP_NAME=FraudDetection

# Flask Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5050
FLASK_DEBUG=True

# Spark JDBC Driver (update this path if needed)
POSTGRES_JDBC_JAR=C:/Spark/spark/jars/postgresql-42.7.8.jar

CUSTOMER_DATA_FILE=E:/Project/DataPulse/data/customer.csv
TRANSACTION_DATA_FILE=E:/Project/DataPulse/data/transactions.csv
